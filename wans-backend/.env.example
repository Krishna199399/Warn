PORT=5000
MONGO_URI=mongodb://username:password@host:port/database?options
JWT_SECRET=generate_with_crypto_randomBytes_32_hex
JWT_REFRESH_SECRET=generate_with_crypto_randomBytes_32_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Razorpay Payment Gateway
# Test keys for development - replace with live keys in production
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=generate_with_crypto_randomBytes_32_hex

# CSRF Protection
CSRF_SECRET=generate_with_crypto_randomBytes_32_hex

# Instructions:
# 1. Copy this file to .env
# 2. Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Replace all placeholder values with actual credentials
# 4. NEVER commit .env file to version control
